# AEGIS Autonomous Defense Platform
# Copy to .env and fill in values
# For Docker deployment, most defaults work out of the box.

# Core
AEGIS_ENV=production
AEGIS_SECRET_KEY=change-me-to-random-string
AEGIS_API_PORT=8000

# AI Provider (set one)
# OpenRouter (recommended - free models available)
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# For OpenAI: set BASE_URL=https://api.openai.com/v1
# For Ollama: set BASE_URL=http://host.docker.internal:11434/v1, KEY=ollama

# Database (Docker-managed PostgreSQL)
POSTGRES_HOST=aegis-db
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=change-me-to-random-string
DATABASE_URL=postgresql+asyncpg://aegis:change-me-to-random-string@aegis-db:5432/aegis

# Event Bus
USE_MEMORY_BUS=true
REDIS_URL=redis://aegis-redis:6379

# Scanning tools (paths inside container)
NUCLEI_PATH=nuclei
NMAP_PATH=/usr/bin/nmap
SUBFINDER_PATH=subfinder
HTTPX_PATH=httpx

# Notifications (optional)
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Mac Pro <-> Pi firewall channel auth (B5 / P0-12)
# Shared secret sent by app/core/firewall_client.py as header
# X-AEGIS-FW-Auth and checked by firewall-agent/main.py on the Pi. Must be
# the SAME value on both sides (Mac Pro backend .env AND the Pi's
# aegis-firewall.service systemd unit). If left unset on the Pi agent, the
# agent runs in optional-accept compat mode (no auth enforced) so a staged
# rollout never locks AEGIS out of live IP blocking — set it on both sides
# together to enforce auth.
AEGIS_FIREWALL_SECRET=

# Node app <-> backend shared secret for unauthenticated node-facing
# endpoints (/nodes/heartbeat, /nodes/announce, /nodes/status/{code},
# /nodes/events, /nodes/report-assets), sent as header X-AEGIS-Node-Auth.
# EndpointAgent has no per-node secret field yet, so this is a single
# shared secret for all nodes. If unset, these endpoints accept requests
# unauthenticated (compat mode) exactly as before this variable existed.
AEGIS_NODE_SECRET=
